# Naeth · modulo `memory` de CENIT. Copia a .env y ajusta. NO commitear .env real.
#
# OJO: los secretos del NUCLEO (CENIT_DB_PASSWORD, OIDC_CLIENT_ID, OIDC_CLIENT_SECRET)
# NO van aqui: los inyecta up.ps1 al vuelo descifrando SOPS. Este fichero solo lleva
# la configuracion no sensible del modulo.

# --- Postgres local (legacy) ---
# Solo lo usa el servicio `db` de este compose, RETIRADO desde el cutover del 17/07:
# los datos viven en el Postgres del nucleo (modules-db) y se conserva como rollback
# en frio. El DSN real de api/worker/viewer apunta a modules-db.
POSTGRES_USER=naeth
POSTGRES_PASSWORD=naeth
POSTGRES_DB=naeth
DB_PORT=5433                 # puerto loopback para inspeccion (127.0.0.1:5433)

# --- Embeddings ---
# CRITICO PARA MULTI-NODO (Paso 8 de CENIT): la dimension debe ser IDENTICA en todos los
# nodos. La replicacion logica copia la columna `embedding vector(N)` tal cual, y un nodo
# con vector(384) frente a otro con vector(1024) falla por tipo incompatible.
# Por eso los defaults del docker-compose.yml valen ya 1024/e5-large: un nodo nuevo que
# arranque SIN .env crea el esquema correcto en vez de romper el sync mas tarde.
# (Deroga la nota del Paso 7 que asignaba e5-small 384-dim a `finally`: valia cuando el
# sync iba a ser a nivel de aplicacion y los embeddings no viajaban entre nodos.)
EMBED_MODEL=intfloat/multilingual-e5-large
EMBED_DIM=1024

# EMBED_PREFIX NO se pasa al contenedor en el compose: el valor efectivo es el default
# del codigo (`e5` en app/embeddings.py). Ponerlo aqui NO tiene efecto; para cambiarlo
# habria que anadirlo tambien al compose.
# EMBED_PREFIX=e5            # e5 -> prefijos passage/query ; none -> MiniLM/bge-m3

# --- API + visor ---
API_PORT=8800              # /mcp con OAuth en http://127.0.0.1:8800
                           # visor + /api + /mcp sin auth van en 8801 (servicio `viewer`)

# Bearer del MCP local. Vacio desde que la auth va por OIDCProxy.
BEARER_TOKEN=

# --- Auth (Fase 4 de CENIT) ---
# Naeth ya NO es su propio Authorization Server: valida contra Pocket-ID via OIDCProxy.
# OAUTH_PROVIDER/BASE_URL y OIDC_CONFIG_URL estan fijados en el docker-compose.yml.
OAUTH_ENABLED=1

# --- Paso 10: autoria ---
# warn = guarda aunque el agente no declare modelo; strict = lo rechaza (instructivo).
# Activar strict SOLO cuando los clientes hayan recargado el schema de las tools.
AUTHORSHIP_ENFORCE=strict

# --- Almacenamiento ---
# pgdata vive en el volumen Docker (disk image de Docker Desktop en F:).
# Binarios de adjuntos por bind-mount; crear la carpeta antes de levantar.
# En el nodo `finally` (Linux) DEBE apuntar a una ruta POSIX: el default del compose
# es una ruta de Windows y alli no vale.
ASSETS_PATH=E:/naeth/assets
