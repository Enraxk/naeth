# Naeth v1 · Fase 1 (Paso 7). Copia a .env y ajusta. NO commitear .env real.

# --- Postgres ---
POSTGRES_USER=naeth
POSTGRES_PASSWORD=naeth
POSTGRES_DB=naeth
DB_PORT=5433                 # puerto loopback para inspeccion (127.0.0.1:5433)

# --- Embeddings por-nodo (Paso 7 §8) ---
# Fase 1 local: e5-small 384. bge-m3 1024 se evalua en Fase 2.
# EMBED_DIM debe coincidir con la dimension real del modelo (el worker lo verifica).
# Nota: fastembed 0.5.1 no trae e5-small; usamos el equivalente multilingue 384-dim
# soportado (mismo tamano de vector, ligero, espanol). e5/bge-m3 entran en Fase 2.
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBED_DIM=384
EMBED_PREFIX=none          # e5 -> prefijos passage/query ; none -> MiniLM/bge-m3

# --- API + visor (solo loopback) ---
API_PORT=8800              # visor en http://127.0.0.1:8800

# Bearer para el MCP local (Fase 2). Vacio en Fase 1.
BEARER_TOKEN=

# --- OAuth 2.1 (Fase 3) ---
# OAUTH_ENABLED=1 activa el Authorization Server (DCR + PKCE) en /mcp.
# Vacio = sin OAuth (Claude Code por localhost, Fase 2).
OAUTH_ENABLED=
OAUTH_BASE_URL=http://127.0.0.1:8800
OAUTH_PROVIDER=postgres                  # postgres (3b, con login) | memory (3a)
# Login de 1 usuario (Fase 3b).
NAETH_AUTH_USER=
NAETH_AUTH_PASSWORD=

# --- Almacenamiento (decidido 2026-06-24) ---
# pgdata vive en el volumen Docker (mover la disk image de Docker Desktop a F:).
# Binarios de adjuntos en E: (bind-mount). Crear la carpeta antes de levantar.
ASSETS_PATH=E:/naeth/assets
